rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Avatar uploads
    match /avatars/{userId}/{fileName} {
      allow read: if true; // Publicly readable
      allow write: if isOwner(userId);
    }

    // Chat images
    match /chats/{chatId}/{fileName} {
      // In a production app, you'd want to check if the user is in the chat
      // This requires getting the chat doc from Firestore, which Storage rules can do
      // but it's more complex. For now, we'll ensure they are at least signed in.
      allow read: if isSignedIn();
      allow write: if isSignedIn(); 
    }
  }
}
