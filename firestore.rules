rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // OTPs and Rate Limits - Backend Only (deny all client requests)
    match /otps/{otpId} {
      allow read, write: if false;
    }
    match /rate_limits/{limitId} {
      allow read, write: if false;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwner(userId);
      allow delete: if false; // Disallow user deletion via client
    }

    // Chats Collection
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.users;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.users;
      allow update: if isSignedIn() && request.auth.uid in resource.data.users;
      
      // Messages subcollection (if applicable, otherwise messages might be in a top-level collection)
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.users;
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId;
      }
    }

    // Requests Collection
    match /requests/{requestId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.fromId || request.auth.uid == resource.data.toId);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.fromId;
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.fromId || request.auth.uid == resource.data.toId);
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn(); // Allow system or other users to trigger notifications
      allow update: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // Reports Collection
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false; // Only admin can read reports
    }
  }
}
